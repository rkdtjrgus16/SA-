# ============================================================
# 마이샵 환경변수 양식
# ------------------------------------------------------------
# 사용 방법:
#   1) 이 파일을 복사해서 같은 폴더에 ".env" 라는 이름으로 만드세요.
#   2) 아래 "여기에_키_붙여넣기" 부분을 본인의 OpenAI API 키로 교체.
#   3) 개발 서버를 재시작 (npm run dev).
#   4) 끝! 사이트의 AI 기능이 자동으로 작동합니다.
#
# 키 발급: https://platform.openai.com/api-keys
# 주의: .env 파일은 절대 깃에 커밋하지 마세요 (.gitignore 에 등록되어 있음).
# ============================================================

VITE_OPENAI_API_KEY=여기에_키_붙여넣기

# (선택) 사용할 모델 — 비워두면 gpt-4o-mini 가 기본값입니다.
# 옵션: gpt-4o-mini (저렴/빠름), gpt-4o (고품질), gpt-4.1-mini, gpt-4.1
VITE_OPENAI_MODEL=gpt-4o-mini
